-- LocalScript (поместить в StarterPlayerScripts)
-- GUI не исчезает после респауна (ResetOnSpawn = false)
-- Кнопки:
--  - "godmode" — режим бессмертия + отслеживание касаний с MapBorders / SafeZoneBorder
--  - "safe"   — телепортирует локального игрока на указанные координаты

local Players = game:GetService("Players")
local workspace = game:GetService("Workspace")

local localPlayer = Players.LocalPlayer
if not localPlayer then return end

local playerGui = localPlayer:WaitForChild("PlayerGui")

local screenGui = playerGui:FindFirstChild("GodmodeGui")
if not screenGui then
    screenGui = Instance.new("ScreenGui")
    screenGui.Name = "GodmodeGui"
    screenGui.ResetOnSpawn = false
    screenGui.Parent = playerGui
end

-- godmode button
local button = screenGui:FindFirstChild("godmode")
if not button then
    button = Instance.new("TextButton")
    button.Name = "godmode"
    button.Size = UDim2.new(0, 140, 0, 40)
    button.Position = UDim2.new(0, 10, 0, 10)
    button.Text = "godmode: OFF"
    button.BackgroundColor3 = Color3.fromRGB(200, 0, 0)
    button.TextColor3 = Color3.fromRGB(255, 255, 255)
    button.Parent = screenGui
end

-- safe button
local safeButton = screenGui:FindFirstChild("safe")
if not safeButton then
    safeButton = Instance.new("TextButton")
    safeButton.Name = "safe"
    safeButton.Size = UDim2.new(0, 140, 0, 40)
    safeButton.Position = UDim2.new(0, 10, 0, 60)
    safeButton.Text = "safe"
    safeButton.BackgroundColor3 = Color3.fromRGB(0, 120, 200)
    safeButton.TextColor3 = Color3.fromRGB(255, 255, 255)
    safeButton.Parent = screenGui
end

local godEnabled = false
local activeConnections = {}
local function clearConnections()
    for _, conn in ipairs(activeConnections) do
        if conn and conn.Disconnect then
            pcall(function() conn:Disconnect() end)
        end
    end
    activeConnections = {}
end

local function isPartInTarget(otherPart)
    if not otherPart or not otherPart:IsA("BasePart") then return false end
    local mb = workspace:FindFirstChild("MapBorders")
    if mb and otherPart:IsDescendantOf(mb) then return true end
    local sz = workspace:FindFirstChild("SafeZoneBorder")
    if sz and otherPart:IsDescendantOf(sz) then return true end
    return false
end

local function setupCharacter(character)
    clearConnections()

    local humanoid = character:FindFirstChildOfClass("Humanoid") or character:WaitForChild("Humanoid", 5)
    if not humanoid then return end

    if humanoid:GetAttribute("Godmode_OrigMaxHealth") == nil then
        humanoid:SetAttribute("Godmode_OrigMaxHealth", humanoid.MaxHealth)
    end

    humanoid.MaxHealth = 1e9
    humanoid.Health = humanoid.MaxHealth

    local healthConn = humanoid.HealthChanged:Connect(function()
        if godEnabled and humanoid and humanoid.Health < humanoid.MaxHealth then
            humanoid.Health = humanoid.MaxHealth
        end
    end)
    table.insert(activeConnections, healthConn)

    local function attachTouchToPart(part)
        if not part or not part:IsA("BasePart") then return end
        local conn = part.Touched:Connect(function(other)
            if not godEnabled then return end
            if isPartInTarget(other) then
                print("[godmode] Часть персонажа коснулась границы:", other:GetFullName())
            end
        end)
        table.insert(activeConnections, conn)
    end

    for _, desc in ipairs(character:GetDescendants()) do
        if desc:IsA("BasePart") then
            attachTouchToPart(desc)
        end
    end

    local descConn = character.DescendantAdded:Connect(function(desc)
        if desc:IsA("BasePart") then
            attachTouchToPart(desc)
        end
    end)
    table.insert(activeConnections, descConn)
end

local function enableGodmode()
    godEnabled = true
    button.Text = "godmode: ON"
    button.BackgroundColor3 = Color3.fromRGB(0, 180, 0)

    if localPlayer.Character then
        setupCharacter(localPlayer.Character)
    end

    local charConn = localPlayer.CharacterAdded:Connect(function(char)
        char:WaitForChild("Humanoid", 10)
        setupCharacter(char)
    end)
    table.insert(activeConnections, charConn)
end

local function disableGodmode()
    godEnabled = false
    button.Text = "godmode: OFF"
    button.BackgroundColor3 = Color3.fromRGB(200, 0, 0)

    if localPlayer.Character then
        local humanoid = localPlayer.Character:FindFirstChildOfClass("Humanoid")
        if humanoid then
            local orig = humanoid:GetAttribute("Godmode_OrigMaxHealth")
            if orig then
                humanoid.MaxHealth = orig
                humanoid.Health = math.min(humanoid.Health, orig)
                humanoid:SetAttribute("Godmode_OrigMaxHealth", nil)
            end
        end
    end

    clearConnections()
end

button.MouseButton1Click:Connect(function()
    if godEnabled then
        disableGodmode()
    else
        enableGodmode()
    end
end)

-- safe: телепорт на конкретные координаты
local safeDebounce = false
local TARGET_POS = Vector3.new(-169.878632, 0.0999994874, -371.975464)

local function teleportToTargetCoords()
    if safeDebounce then return end
    safeDebounce = true
    delay(0.5, function() safeDebounce = false end)

    local char = localPlayer.Character or (localPlayer.CharacterAdded and localPlayer.CharacterAdded:Wait())
    if not char then
        warn("[safe] Не удалось получить Character локального игрока")
        return
    end

    local hrp = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChildWhichIsA("BasePart")
    if not hrp then
        warn("[safe] У персонажа нет HumanoidRootPart / частей для перемещения")
        return
    end

    local ok, err = pcall(function()
        hrp.CFrame = CFrame.new(TARGET_POS)
    end)
    if not ok then
        warn("[safe] Ошибка при телепорте:", err)
    else
        local prevText = safeButton.Text
        safeButton.Text = "safe: Teleported"
        delay(1.5, function()
            if safeButton then safeButton.Text = prevText end
        end)
        print("[safe] Телепорт выполнен на координаты:", TARGET_POS)
    end
end

safeButton.MouseButton1Click:Connect(function()
    teleportToTargetCoords()
end)

